# Exemple de configuration .env pour le pipeline LLM generation.
# Copier ce fichier en .env (a la racine de data_pipeline/) et remplir.

# ─── Cles API LLM ────────────────────────────────────────────────────
# Les 3 cles sont necessaires pour la cross-validation 2/3 LLM.
# Si une cle est absente, le LLM correspondant est skip silencieusement
# (la cross-validation fonctionnera avec 2 LLM, mais 1 LLM seul ne
# produira aucune question validee).

# Anthropic (Claude Sonnet 4) - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (GPT-4o) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mistral AI (Mistral Large) - https://console.mistral.ai/api-keys
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Modeles (optionnel - surcharge les valeurs par defaut) ──────────
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
MISTRAL_MODEL=mistral-large-latest

# ─── Logging (optionnel) ─────────────────────────────────────────────
LOG_LEVEL=INFO
