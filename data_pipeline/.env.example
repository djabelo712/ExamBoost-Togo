# Copier ce fichier en .env et remplir les valeurs

# Cle API OpenAI (obligatoire pour l'OCR Vision et la structuration)
OPENAI_API_KEY=sk-votre-cle-ici

# Modeles OpenAI
OPENAI_VISION_MODEL=gpt-4o
OPENAI_STRUCTURE_MODEL=gpt-4o-mini

# Parametres OCR
TESSERACT_LANG=fra
OCR_DPI=300

# Politisme de scraping
SCRAPER_DELAY_SECONDS=1.0
SCRAPER_USER_AGENT=ExamBoostBot/1.0 (+contact@examboost.tg)

# Coûts estimes (pour suivi budget)
COST_PER_VISION_PAGE=0.01
