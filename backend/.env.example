# ─── ExamBoost Togo - Backend environment variables ─────────────────────
# Copy this file to `.env` (local dev) or set the variables in the Railway
# dashboard for staging/production. Never commit the real `.env`.

# ─── Database ───────────────────────────────────────────────────────────
# Local dev: SQLite file (auto-created on first run).
# Production (Railway): use ${{Postgres.DATABASE_URL}} in the Railway UI.
DATABASE_URL=sqlite:///./examboost.db
# Examples:
#   postgresql://user:pass@host:5432/examboost
#   postgresql+psycopg://user:pass@host:5432/examboost

# ─── Auth / JWT ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production-please-use-a-32-char-min-secret
ALGORITHM=HS256
# Token lifetime in minutes. 10080 = 7 days.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ─── CORS ───────────────────────────────────────────────────────────────
# Either a JSON array or a comma-separated list of origins.
# Local dev:
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
# Production (comma-separated):
# CORS_ORIGINS=https://examboost-togo.vercel.app,https://examboost.tg,https://www.examboost.tg

# ─── Default admin (used by POST /questions without auth in dev) ─────────
ADMIN_EMAIL=admin@examboost.tg

# ─── BKT / IRT tuning (optional, sensible defaults) ─────────────────────
BKT_P_LEARN=0.20
BKT_P_SLIP=0.10
BKT_P_GUESS=0.20
BKT_MASTERY_THRESHOLD=0.85
MIN_RESPONSES_FOR_ML=100

# ─── External APIs ──────────────────────────────────────────────────────
# Anthropic (Claude) for the tutor chat endpoint. Optional: tutor falls
# back to a mock pedagogical response if the key is absent.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (used by the OCR data pipeline, optional for the API itself).
OPENAI_API_KEY=sk-...

# Africa's Talking (SMS notifications - optional).
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=EXAMBOOST
AFRICASTALKING_USERNAME=examboost

# ─── Redis (optional, for cache + rate limiting sharing across workers) ──
# Leave blank to use in-memory rate limiting (default).
REDIS_URL=

# ─── Object storage (optional, for OCR PDFs and question images) ────────
S3_BUCKET=examboost-assets
S3_REGION=af-south-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# ─── Monitoring ─────────────────────────────────────────────────────────
# PostHog (product analytics, optional).
POSTHOG_API_KEY=
# Sentry (error tracking, optional).
SENTRY_DSN=

# ─── Runtime ────────────────────────────────────────────────────────────
# development | staging | production
ENVIRONMENT=development
# debug | info | warning | error
LOG_LEVEL=info
# Port the FastAPI app listens on. Railway injects $PORT automatically.
PORT=8000
