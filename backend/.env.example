# ─── ExamBoost Togo — Backend environment variables ─────────────────
# Copier ce fichier en .env et adapter les valeurs.

# Base de donnees : SQLite en dev, PostgreSQL en prod (Railway/Render)
DATABASE_URL=sqlite:///./examboost.db

# Cle secrete JWT — generer avec : openssl rand -hex 32
SECRET_KEY=change-me-in-production-please-use-a-32-char-min-secret

# Duree de validite du token JWT (minutes) — 10080 = 7 jours
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS : origines autorisees (separees par des virgules)
CORS_ORIGINS=["*"]

# Algorithme JWT
ALGORITHM=HS256

# Admin par defaut (pour POST /questions sans utilisateur authentifie en prod)
ADMIN_EMAIL=admin@examboost.tg
