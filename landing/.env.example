# Copy to .env.local for local development, or set in the Vercel dashboard
# for preview/production deployments.

# ─── API ────────────────────────────────────────────────────────────────
# Backend FastAPI URL.
# Local dev (point to your local backend):
NEXT_PUBLIC_API_URL=http://localhost:8000
# Staging:
# NEXT_PUBLIC_API_URL=https://examboost-togo-staging.up.railway.app
# Production:
# NEXT_PUBLIC_API_URL=https://examboost-togo.up.railway.app

# ─── Repository ─────────────────────────────────────────────────────────
NEXT_PUBLIC_GITHUB_URL=https://github.com/djabelo712/ExamBoost-Togo

# ─── Site URL (used for canonical metadata + OpenGraph) ─────────────────
# Local dev:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production:
# NEXT_PUBLIC_SITE_URL=https://examboost-togo.vercel.app

# ─── Beta signup webhook (optional) ─────────────────────────────────────
# If set, the /api/beta-signup route will POST a JSON payload to this URL
# in addition to writing to data/signups.json. Useful for forwarding to
# Mailchimp, ConvertKit, or a Slack incoming webhook.
# BETA_WEBHOOK_URL=

# ─── Analytics (optional) ───────────────────────────────────────────────
# PostHog project API key (public, safe to expose).
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─── Sentry (optional, server-side only) ────────────────────────────────
# SENTRY_DSN=
